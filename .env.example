# Transport Management System - Environment Variables
# Copy this file to .env and modify values for your environment

# Django Secret Key (generate a new one for production)
SECRET_KEY=django-insecure-transport-mgmt-system-key-change-in-production

# Debug mode (set to False for production)
DEBUG=True

# Allowed hosts (comma-separated list)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Database URL (optional - defaults to SQLite)
# DATABASE_URL=sqlite:///db.sqlite3

# Google Drive Storage (for Documents)
# Path to the JSON key file you downloaded in Step 1
GOOGLE_DRIVE_STORAGE_JSON_KEY_FILE=path/to/your-service-account-key.json
# The Folder ID from the URL in Step 2
GOOGLE_DRIVE_STORAGE_MEDIA_ROOT=your_google_drive_folder_id_here